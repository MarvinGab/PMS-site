# Copy this file to .env and fill in your values.
# Frontend uses only the public anon key.
# Never expose the Supabase service-role key in Vite env vars.

VITE_BACKEND_MODE=local
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_GEMINI_API_KEY=
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
FROM_NAME=
SMTP_FROM=
SMTP_CONFIG_SECRET=
APP_AUTH_SUPER_ADMIN_EMAIL=
APP_AUTH_SUPER_ADMIN_PASSWORD=
APP_AUTH_SUPER_ADMIN_PASSWORD_HASH=
VITE_SUPER_ADMIN_EMAIL=
VITE_SUPER_ADMIN_PASSWORD=
